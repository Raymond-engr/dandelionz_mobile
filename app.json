{
  "expo": {
    "name": "Dandelionz",
    "slug": "Dandelionz",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dandelionz",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "linking": {
      "prefixes": [
        "dandelionz://",
        "https://app.dandelionz.com.ng",
        "https://dandelionz.com.ng",
        "https://*.dandelionz.com.ng"
      ],
      "config": {
        "screens": {
          "forgot-password-confirm": "forgot-password/confirm",
          "verify-email": "verify-email",
          "(tabs)": {
            "screens": {
              "index": "shop",
              "cart": "cart",
              "orders": "orders",
              "wishlist": "wishlist",
              "account": "account"
            }
          },
          "(auth)": {
            "screens": {
              "login": "login",
              "register": "register",
              "forgot-password": "forgot-password",
              "registration-success": "registration-success",
              "verify-notice": "verify-notice"
            }
          },
          "category/[name]": "category/:name",
          "product/[slug]": "product/:slug",
          "customer-profile": "account/profile",
          "account/delivery-address": "account/address",
          "customer-notifications": "account/notifications",
          "account/change-password": "account/change-password",
          "account/delete-account": "account/delete",
          "account/invite-friends": "account/invite-friends",
          "checkout/success": "checkout/success",
          "checkout/webview": "checkout/pay",
          "order-tracking": "orders/:id",
          "order-receipt": "receipt/:id",
          "(admin)/payment-settings/forgot-pin": "admin/forgot-pin",
          "(admin)/(tabs)/index": "admin",
          "(admin)/(tabs)/orders": "admin/orders",
          "(admin)/(tabs)/product": "admin/product",
          "(admin)/(tabs)/users": "admin/users",
          "(admin)/(tabs)/vendor": "admin/vendor",
          "vendor": {
            "screens": {
              "wallet/history": "vendor/wallet/history",
              "wallet/receipt": "vendor/wallet/receipt/:id",
              "account/profile": "vendor/profile",
              "account/payment-settings": "vendor/payment-settings",
              "account/forgot-pin": "vendor/forgot-pin",
              "account/notifications": "vendor/notifications",
              "account/change-password": "vendor/change-password",
              "account/delete": "vendor/delete-account"
            }
          },
          "contact": "contact",
          "faqs": "faqs",
          "terms": "terms"
        }
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dandelionz",
      "associatedDomains": [
        "applinks:dandelionz.com.ng",
        "applinks:app.dandelionz.com.ng"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.dandelionz",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "dandelionz.com.ng",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "app.dandelionz.com.ng",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": ["https://maven.google.com"]
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "95497ecd-0fd2-43d5-9078-c1a54f1f3aa4"
      }
    }
  }
}
